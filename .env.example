# --- Build-time (NEXT_PUBLIC_*) ---

NEXT_PUBLIC_DOMAIN=https://example.com
NEXT_PUBLIC_TURNSTILE_SITEKEY=1x00000000000000000000AA
NEXT_PUBLIC_WS_URL=https://ws.example.com
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=generate-a-base64-32-byte-key


# --- Runtime secrets (SERVER-ONLY*) ---

# WebSocket Server
WEBSOCKET_SERVER_URL=http://localhost:3002
INTERNAL_API_KEY=generate-a-shared-secret

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# Cache & Session (Redis)
# - Redis server certificate path (for rediss:// URLs)
REDIS_CERT_PATH=app/certs/../ca.crt
REDIS_URL=redis://localhost:6379

# Media Caching (WASM + Redis)
MEDIA_CACHE_ENABLED=true
MEDIA_CACHE_MAX_OBJECT_MB=2
MEDIA_CACHE_TTL_SEC_SUPPORT=3600
MEDIA_CACHE_TTL_SEC_AVATARS=86400

# Security
CSRF_SECRET=generate-a-strong-secret
USER_DATA_SECRET=generate-a-strong-secret
TURNSTILE_SECRET_KEY=0x000000000000000000000000000000000

# Storage (S3)
S3_ENDPOINT=https://s3.example.com
S3_BUCKET=my-bucket
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_REGION=us-east-1

# Geolocation MaxMind GeoLite2
MAXMIND_DB_PATH=./data/GeoLite2-City.mmdb

# OAuth: Yandex
YANDEX_CLIENT_ID=your-client-id
YANDEX_CLIENT_SECRET=your-client-secret

# OAuth: Google
GOOGLE_CLIENT_ID=your-client-id
GOOGLE_CLIENT_SECRET=your-client-secret

# OAuth: Telegram
TELEGRAM_BOT_USERNAME=your-bot-username
TELEGRAM_BOT_TOKEN=your-bot-token

# OAuth: VK
VK_CLIENT_ID=your-client-id
VK_CLIENT_SECRET=your-client-secret

# OAuth: Twitch
TWITCH_CLIENT_ID=your-client-id
TWITCH_CLIENT_SECRET=your-client-secret

# OAuth: GitHub
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret
